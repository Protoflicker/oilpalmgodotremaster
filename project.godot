[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Panen Sawit"
run/main_scene="uid://ddjy0kbrl7skn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

SimpleGrass="*res://addons/simplegrasstextured/singleton.tscn"
NoiseManager="*res://Script/NoiseManager.gd"
GameState="*res://Script/GameState.gd"
Loc="*res://Script/Loc.gd"
Settings="*res://Script/Settings.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=4
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="palm-s oil ninja"

[editor_plugins]

enabled=PackedStringArray("res://addons/simplegrasstextured/plugin.cfg")

[filesystem]

import/fbx2gltf/enabled.android=true
import/fbx2gltf/enabled.web=true

